import { Elysia } from "elysia";
import { cors } from "@elysiajs/cors";
import { swagger } from "@elysiajs/swagger";
import { env } from "./env";

const app = new Elysia()
  .use(cors())
  .use(swagger())
  .get("/", () => ({
    name: "__APP_NAME__",
    message: "Bun + Elysia backend",
    docs: "/swagger",
  }))
  .get("/health", () => ({ status: "ok", uptime: process.uptime(), ts: Date.now() }))
__WITH_AUTH_BLOCK__
  .group("/auth", (a) =>
    a.post("/login", ({ body }) => ({ token: "demo", user: body })).post("/logout", () => ({ ok: true }))
  )
__END__
  .listen(env.PORT);

console.log(`🚀 __APP_NAME__ running at ${app.server?.hostname}:${app.server?.port}`);
